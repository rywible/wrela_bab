{
  "name": "wrela",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vp dev",
    "build": "tsc && vp build",
    "preview": "vp preview",
    "visual:validate": "node scripts/visual-validate.mjs",
    "visual:validate:headed": "node scripts/visual-validate.mjs --headed",
    "visual:validate:electron": "node scripts/electron-visual-validate.mjs",
    "desktop:dev": "node electron/dev.cjs",
    "desktop:run": "vp build && node electron/run.cjs",
    "desktop:pack": "vp build && electron-builder --dir",
    "desktop:dist": "vp build && electron-builder"
  },
  "dependencies": {
    "@babylonjs/core": "^8.56.1"
  },
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "playwright": "^1.58.2",
    "typescript": "~5.9.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "packageManager": "npm@11.12.0",
  "build": {
    "appId": "com.wrela.redwoodslice",
    "productName": "Wrela Redwood Slice",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
